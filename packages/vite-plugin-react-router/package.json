{
  "name": "@netlify/vite-plugin-react-router",
  "version": "4.0.0",
  "description": "React Router 7+ Vite plugin for Netlify",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./serverless": {
      "types": "./dist/serverless.d.ts",
      "default": "./dist/serverless.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "default": "./dist/edge.js"
    },
    "./entry.server.edge": {
      "types": "./dist/entry.server.edge.d.ts",
      "default": "./dist/entry.server.edge.js"
    }
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepack": "pnpm run build",
    "build": "rm -rf dist && tsup-node",
    "build:watch": "pnpm run build --watch",
    "publint": "publint --strict"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/netlify/remix-compute",
    "directory": "packages/vite-plugin-react-router"
  },
  "keywords": [
    "react-router",
    "vite-plugin",
    "netlify"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/netlify/remix-compute/issues"
  },
  "homepage": "https://github.com/netlify/remix-compute#readme",
  "dependencies": {
    "@netlify/edge-functions": "^3.0.6",
    "@netlify/functions": "^5.2.0",
    "@remix-run/node-fetch-server": "^0.13.0",
    "isbot": "^5.1.25",
    "tinyglobby": "^0.2.10"
  },
  "devDependencies": {
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.9.4",
    "tsup": "^8.0.2",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "react-router": ">=7.9.0",
    "vite": ">=6.0.0"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
